<Window x:Class="FilesWidget.FilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="文件收纳盒"
        Width="220" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Topmost="False"
        ShowInTaskbar="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Border CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#4CAF50" Offset="0"/>
                <GradientStop Color="#388E3C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,6,8,6">
                        <Button x:Name="BtnAdd" Content="+" Width="20" Height="20"
                                Background="#30FFFFFF" Foreground="White" BorderThickness="0"
                                FontSize="12" Click="Add_Click" Cursor="Hand"
                                ToolTip="添加文件夹">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnClose" Content="×" Width="20" Height="20"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                FontSize="12" Click="Close_Click" Cursor="Hand" Margin="4,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="文件收纳盒" Foreground="White" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI" Margin="12,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- File Folders List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,4,8,4">
                <ItemsControl x:Name="FoldersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#20FFFFFF" CornerRadius="8" 
                                    Margin="0,3" Padding="8,6" Cursor="Hand"
                                    MouseLeftButtonDown="Folder_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="📁" FontSize="16" 
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                   Foreground="White" FontWeight="SemiBold"
                                                   FontFamily="Microsoft YaHei UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Path}" FontSize="9"
                                                   Foreground="#AAFFFFFF"
                                                   FontFamily="Microsoft YaHei UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="2" Content="×" Width="18" Height="18"
                                            Background="Transparent" Foreground="#AAFFFFFF"
                                            BorderThickness="0" FontSize="10"
                                            Click="RemoveFolder_Click" Cursor="Hand"
                                            Tag="{Binding Path}"
                                            ToolTip="移除">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="9"
                                                        Opacity="0.8">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState" Grid.Row="1" 
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="📂" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="暂无文件夹" FontSize="11" Foreground="#AAFFFFFF"
                           FontFamily="Microsoft YaHei UI" Margin="0,8,0,0"/>
                <TextBlock Text="拖拽文件夹到此处" FontSize="10" Foreground="#88FFFFFF"
                           FontFamily="Microsoft YaHei UI" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Drop Overlay -->
            <Border x:Name="DropOverlay" Grid.Row="1" 
                    Background="#60000000" CornerRadius="8" 
                    Margin="8,4,8,4" Visibility="Collapsed"
                    BorderBrush="#80FFFFFF" BorderThickness="2">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📂" FontSize="36" HorizontalAlignment="Center"/>
                    <TextBlock Text="释放添加文件夹" FontSize="12" Foreground="White"
                               FontFamily="Microsoft YaHei UI" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" Margin="10,0,10,8">
                <TextBlock Text="拖动移动 · 拖拽文件夹添加 · 点击打开" FontSize="9"
                           Foreground="#88FFFFFF" HorizontalAlignment="Center"
                           FontFamily="Microsoft YaHei UI"/>
            </Border>
        </Grid>
    </Border>
</Window>
