<Window x:Class="TodoWidget.TodoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="待办事项"
        Width="280" Height="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Topmost="False"
        ShowInTaskbar="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Border CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#FF6B6B" Offset="0"/>
                <GradientStop Color="#E53935" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,6,8,6">
                        <Button x:Name="BtnSync" Content="⇄" Width="20" Height="20"
                                Background="#30FFFFFF" Foreground="White" BorderThickness="0"
                                FontSize="10" Click="Sync_Click" Cursor="Hand"
                                ToolTip="同步到飞书">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnClose" Content="×" Width="20" Height="20"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                FontSize="12" Click="Close_Click" Cursor="Hand" Margin="4,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="待办事项" Foreground="White" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI" Margin="12,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- Input Area -->
            <Grid Grid.Row="1" Margin="10,6,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnAdd" Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Height="28"
                        Background="#30FFFFFF" Foreground="White"
                        BorderThickness="0"
                        FontSize="12" Click="Add_Click" Cursor="Hand"
                        Content="+ 添加新任务">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- TODO List -->
            <ScrollViewer Grid.Row="2" Margin="10,0,10,10"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TodoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" Padding="10,8"
                                    CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#20FFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Priority}" Value="High">
                                                <Setter Property="BorderBrush" Value="#FF5252"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                <Setter Property="BorderBrush" Value="#FFD740"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                <Setter Property="BorderBrush" Value="#69F0AE"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                              Click="Todo_CheckChanged"
                                              Tag="{Binding Id}"
                                              VerticalAlignment="Top"
                                              Margin="0,2,8,0">
                                        <CheckBox.Template>
                                            <ControlTemplate TargetType="CheckBox">
                                                <Border x:Name="checkBorder" Width="18" Height="18"
                                                        CornerRadius="4" BorderThickness="1.5"
                                                        BorderBrush="White" Background="Transparent">
                                                    <Path x:Name="checkMark" Visibility="Collapsed"
                                                          Data="M3,8 L7,12 L15,4"
                                                          Stroke="White" StrokeThickness="2"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="checkBorder" Property="Background" Value="#50FFFFFF"/>
                                                        <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </CheckBox.Template>
                                    </CheckBox>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Priority Indicator -->
                                            <Border x:Name="PriorityIndicator" Width="8" Height="8"
                                                    CornerRadius="4" Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFD740"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Priority}" Value="High">
                                                                <Setter Property="Background" Value="#FF5252"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                                <Setter Property="Background" Value="#FFD740"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                                <Setter Property="Background" Value="#69F0AE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            
                                            <TextBlock Text="{Binding Title}" Foreground="White"
                                                       FontSize="13" FontFamily="Microsoft YaHei UI"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        
                                        <!-- Notes -->
                                        <TextBlock Text="{Binding Notes}" Foreground="#AAFFFFFF"
                                                   FontSize="11" FontFamily="Microsoft YaHei UI"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Visibility="{Binding Notes, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                                        
                                        <!-- Due Date -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                    Visibility="{Binding DueDate, Converter={StaticResource NullToVisibilityConverter}}">
                                            <TextBlock Text="📅" FontSize="10" Foreground="#AAFFFFFF" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat={}{0:MM/dd}}" 
                                                       FontSize="10" Foreground="#AAFFFFFF"
                                                       FontFamily="Microsoft YaHei UI"/>
                                        </StackPanel>
                                        
                                        <!-- Priority Text -->
                                        <TextBlock FontSize="9" Foreground="#88FFFFFF"
                                                   FontFamily="Microsoft YaHei UI" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="中优先级"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="High">
                                                            <Setter Property="Text" Value="高优先级"/>
                                                            <Setter Property="Foreground" Value="#FFAA80"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                            <Setter Property="Text" Value="中优先级"/>
                                                            <Setter Property="Foreground" Value="#FFFF80"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                            <Setter Property="Text" Value="低优先级"/>
                                                            <Setter Property="Foreground" Value="#80FF80"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="2" Width="20" Height="20"
                                            Background="Transparent" Foreground="#AAFFFFFF"
                                            BorderThickness="0"
                                            Click="Delete_Click" Tag="{Binding Id}"
                                            ToolTip="删除" Cursor="Hand"
                                            VerticalAlignment="Top"
                                            Margin="4,0,0,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                                        Opacity="0.8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="×" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState" Grid.Row="2"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="✓" FontSize="48" Foreground="#40FFFFFF" HorizontalAlignment="Center"/>
                <TextBlock Text="暂无待办事项" FontSize="12" Foreground="#AAFFFFFF"
                           FontFamily="Microsoft YaHei UI" Margin="0,8,0,0"/>
                <TextBlock Text="点击上方按钮添加" FontSize="10" Foreground="#88FFFFFF"
                           FontFamily="Microsoft YaHei UI" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
    
    <Window.Resources>
        <local:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter" xmlns:local="clr-namespace:TodoWidget"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" xmlns:local="clr-namespace:TodoWidget"/>
    </Window.Resources>
</Window>
