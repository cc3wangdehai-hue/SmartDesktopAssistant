<UserControl x:Class="WeatherWidget.WeatherControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="160" d:DesignWidth="280"
             Background="Transparent">
    
    <UserControl.Resources>
        <LinearGradientBrush x:Key="GreenGradient" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#4CAF50" Offset="0"/>
            <GradientStop Color="#388E3C" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- City 1 -->
        <Border x:Name="Card1" Grid.Row="0" 
                Background="{StaticResource GreenGradient}"
                CornerRadius="8" Height="75" Margin="0,0,0,4">
            <Grid>
                <!-- Main Content -->
                <Grid Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="TxtTemp1" Grid.Column="0"
                               Text="22°" FontSize="32" FontWeight="Thin"
                               Foreground="White" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtCity1" Text="北京" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" FontFamily="Microsoft YaHei UI"/>
                            <TextBlock x:Name="TxtCountry1" Text=" 中国" FontSize="9"
                                       Foreground="#CCFFFFFF" Margin="3,2,0,0"
                                       FontFamily="Microsoft YaHei UI"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtDesc1" Text="晴" FontSize="11"
                                   Foreground="#DDFFFFFF" Margin="0,2,0,0"
                                   FontFamily="Microsoft YaHei UI"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="↑" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock x:Name="TxtHigh1" Text="28°" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock Text=" ↓" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock x:Name="TxtLow1" Text="18°" Foreground="#AAFFFFFF" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button x:Name="BtnRefresh1" Grid.Column="2"
                            Width="22" Height="22" Background="#30FFFFFF"
                            BorderThickness="0" Cursor="Hand"
                            Click="Refresh_Click" ToolTip="刷新">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="11">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="⟳" Foreground="White" FontSize="10"/>
                    </Button>
                </Grid>
                
                <!-- Loading Overlay -->
                <Border x:Name="LoadingBorder1" Background="#80000000" CornerRadius="8" Visibility="Collapsed">
                    <TextBlock Text="加载中..." Foreground="White" FontSize="11" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Error Overlay -->
                <Border x:Name="ErrorBorder1" Background="#80000000" CornerRadius="8" Visibility="Collapsed">
                    <TextBlock Text="点击重试" Foreground="White" FontSize="11" Cursor="Hand"
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               MouseLeftButtonDown="Retry_Click"/>
                </Border>
            </Grid>
        </Border>
        
        <!-- City 2 -->
        <Border x:Name="Card2" Grid.Row="1"
                Background="#00a6fb"
                CornerRadius="8" Height="75" Margin="0,4,0,0">
            <Grid>
                <!-- Main Content -->
                <Grid Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="TxtTemp2" Grid.Column="0"
                               Text="25°" FontSize="32" FontWeight="Thin"
                               Foreground="White" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtCity2" Text="上海" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" FontFamily="Microsoft YaHei UI"/>
                            <TextBlock x:Name="TxtCountry2" Text=" 中国" FontSize="9"
                                       Foreground="#CCFFFFFF" Margin="3,2,0,0"
                                       FontFamily="Microsoft YaHei UI"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtDesc2" Text="多云" FontSize="11"
                                   Foreground="#DDFFFFFF" Margin="0,2,0,0"
                                   FontFamily="Microsoft YaHei UI"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="↑" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock x:Name="TxtHigh2" Text="26°" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock Text=" ↓" Foreground="#AAFFFFFF" FontSize="9"/>
                            <TextBlock x:Name="TxtLow2" Text="20°" Foreground="#AAFFFFFF" FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button x:Name="BtnRefresh2" Grid.Column="2"
                            Width="22" Height="22" Background="#30FFFFFF"
                            BorderThickness="0" Cursor="Hand"
                            Click="Refresh_Click" ToolTip="刷新">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="11">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="⟳" Foreground="White" FontSize="10"/>
                    </Button>
                </Grid>
                
                <!-- Loading Overlay -->
                <Border x:Name="LoadingBorder2" Background="#80000000" CornerRadius="8" Visibility="Collapsed">
                    <TextBlock Text="加载中..." Foreground="White" FontSize="11" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Error Overlay -->
                <Border x:Name="ErrorBorder2" Background="#80000000" CornerRadius="8" Visibility="Collapsed">
                    <TextBlock Text="点击重试" Foreground="White" FontSize="11" Cursor="Hand"
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               MouseLeftButtonDown="Retry_Click"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
