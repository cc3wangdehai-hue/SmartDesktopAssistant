<Window x:Class="WeatherWidget.WeatherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="天气预报"
        Width="200" Height="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Topmost="False"
        ShowInTaskbar="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Border CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#4CAF50" Offset="0"/>
                <GradientStop Color="#388E3C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,6,8,6">
                        <Button x:Name="BtnRefresh" Content="⟳" Width="20" Height="20"
                                Background="#30FFFFFF" Foreground="White" BorderThickness="0"
                                FontSize="10" Click="Refresh_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnClose" Content="×" Width="20" Height="20"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                FontSize="12" Click="Close_Click" Cursor="Hand" Margin="4,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="天气预报" Foreground="White" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI" Margin="12,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- Clock Display -->
            <Border Grid.Row="1" Background="#20FFFFFF" Margin="12,4,12,8" Padding="10,8" CornerRadius="8">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtTime" Text="00:00"
                               FontSize="32" FontWeight="Light"
                               Foreground="White" 
                               FontFamily="Microsoft YaHei UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtDate" Text="--/-- 星期--"
                               FontSize="11" FontWeight="Normal"
                               Foreground="#DDFFFFFF" 
                               FontFamily="Microsoft YaHei UI"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- City 1 -->
            <Grid Grid.Row="2" Margin="12,4,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtTemp1" Grid.Column="0"
                           Text="--°" FontSize="32" FontWeight="Thin"
                           Foreground="White" VerticalAlignment="Center"
                           FontFamily="Microsoft YaHei UI"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtCity1" Text="北京" FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDesc1" Text="--" FontSize="11"
                               Foreground="#DDFFFFFF" Margin="0,2,0,0"
                               FontFamily="Microsoft YaHei UI"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="↑" Foreground="#AAFFFFFF" FontSize="10"/>
                        <TextBlock x:Name="TxtHigh1" Text="--°" Foreground="#AAFFFFFF" FontSize="10"/>
                        <TextBlock Text=" ↓" Foreground="#AAFFFFFF" FontSize="10"/>
                        <TextBlock x:Name="TxtLow1" Text="--°" Foreground="#AAFFFFFF" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- City 2 -->
            <Grid Grid.Row="3" Margin="12,4,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtTemp2" Grid.Column="0"
                           Text="--°" FontSize="32" FontWeight="Thin"
                           Foreground="White" VerticalAlignment="Center"
                           FontFamily="Microsoft YaHei UI"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtCity2" Text="上海" FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" FontFamily="Microsoft YaHei UI"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDesc2" Text="--" FontSize="11"
                               Foreground="#DDFFFFFF" Margin="0,2,0,0"
                               FontFamily="Microsoft YaHei UI"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="↑" Foreground="#AAFFFFFF" FontSize="10"/>
                        <TextBlock x:Name="TxtHigh2" Text="--°" Foreground="#AAFFFFFF" FontSize="10"/>
                        <TextBlock Text=" ↓" Foreground="#AAFFFFFF" FontSize="10"/>
                        <TextBlock x:Name="TxtLow2" Text="--°" Foreground="#AAFFFFFF" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Loading -->
            <Border x:Name="LoadingBorder" Grid.Row="0" Grid.RowSpan="4"
                    Background="#80000000" CornerRadius="12" Visibility="Collapsed">
                <TextBlock Text="加载中..." Foreground="White" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <!-- Error -->
            <Border x:Name="ErrorBorder" Grid.Row="0" Grid.RowSpan="4"
                    Background="#80000000" CornerRadius="12" Visibility="Collapsed">
                <TextBlock Text="点击重试" Foreground="White" FontSize="12" Cursor="Hand"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           MouseLeftButtonDown="Retry_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
