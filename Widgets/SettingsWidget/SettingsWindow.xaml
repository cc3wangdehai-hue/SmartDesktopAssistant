<Window x:Class="SettingsWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="设置"
        Width="320" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Border CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#4CAF50" Offset="0"/>
                <GradientStop Color="#388E3C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0">
                <DockPanel>
                    <Button x:Name="BtnClose" Content="×" Width="24" Height="24"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="14" Click="Close_Click" Cursor="Hand" Margin="0,0,10,0"
                            DockPanel.Dock="Right">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="⚙ 设置" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI" Margin="16,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- Settings Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,8,16,16">
                <StackPanel>
                    <!-- Weather Section -->
                    <TextBlock Text="天气设置" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Microsoft YaHei UI" Margin="0,0,0,10"/>
                    <Border Background="#20FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <!-- City 1 -->
                            <TextBlock Text="城市 1" Foreground="#DDFFFFFF" FontSize="11"
                                       FontFamily="Microsoft YaHei UI" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtCity1" Text="北京"
                                     Background="#30FFFFFF" Foreground="White"
                                     CaretBrush="White" BorderThickness="0"
                                     Padding="8,6" FontSize="12"
                                     FontFamily="Microsoft YaHei UI"/>
                            
                            <!-- City 2 -->
                            <TextBlock Text="城市 2" Foreground="#DDFFFFFF" FontSize="11"
                                       FontFamily="Microsoft YaHei UI" Margin="0,10,0,4"/>
                            <TextBox x:Name="TxtCity2" Text="上海"
                                     Background="#30FFFFFF" Foreground="White"
                                     CaretBrush="White" BorderThickness="0"
                                     Padding="8,6" FontSize="12"
                                     FontFamily="Microsoft YaHei UI"/>
                        </StackPanel>
                    </Border>

                    <!-- Widget Visibility Section -->
                    <TextBlock Text="组件显示/隐藏" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Microsoft YaHei UI" Margin="0,0,0,10"/>
                    <Border Background="#20FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowWeather" Content="显示天气组件" IsChecked="True"
                                      Foreground="White" FontSize="12" FontFamily="Microsoft YaHei UI"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="ChkShowTodo" Content="显示待办组件" IsChecked="True"
                                      Foreground="White" FontSize="12" FontFamily="Microsoft YaHei UI"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="ChkShowFiles" Content="显示文件组件" IsChecked="True"
                                      Foreground="White" FontSize="12" FontFamily="Microsoft YaHei UI"/>
                        </StackPanel>
                    </Border>

                    <!-- Startup Section -->
                    <TextBlock Text="系统设置" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Microsoft YaHei UI" Margin="0,0,0,10"/>
                    <Border Background="#20FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <CheckBox x:Name="ChkAutoStart" Content="开机自动启动" IsChecked="False"
                                      Foreground="White" FontSize="12" FontFamily="Microsoft YaHei UI"
                                      Checked="ChkAutoStart_Changed"
                                      Unchecked="ChkAutoStart_Changed"/>
                            <TextBlock Text="将在系统启动时自动运行助手" Foreground="#88FFFFFF"
                                       FontSize="10" FontFamily="Microsoft YaHei UI"
                                       Margin="24,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="取消" Width="90" Height="32"
                                Background="#40FFFFFF" Foreground="White"
                                BorderThickness="0" FontSize="12"
                                FontFamily="Microsoft YaHei UI"
                                Click="Cancel_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="保存" Width="90" Height="32" Margin="12,0,0,0"
                                Background="#FFFFFF" Foreground="#388E3C"
                                BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                FontFamily="Microsoft YaHei UI"
                                Click="Save_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
