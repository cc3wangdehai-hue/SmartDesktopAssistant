<Window x:Class="ClockWidget.ClockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="时钟"
        Width="180" Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Topmost="False"
        ShowInTaskbar="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Border CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#4CAF50" Offset="0"/>
                <GradientStop Color="#388E3C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,4,6,4">
                        <Button x:Name="BtnClose" Content="×" Width="18" Height="18"
                                Background="Transparent" Foreground="White" BorderThickness="0"
                                FontSize="11" Click="Close_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="9">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="时钟" Foreground="White" FontSize="10"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Microsoft YaHei UI" Margin="10,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- Time Display -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtTime" Text="00:00"
                           FontSize="42" FontWeight="Light"
                           Foreground="White" 
                           FontFamily="Microsoft YaHei UI"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Date Display -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock x:Name="TxtDate" Text="--/-- 星期--"
                           FontSize="12" FontWeight="Normal"
                           Foreground="#DDFFFFFF" 
                           FontFamily="Microsoft YaHei UI"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
